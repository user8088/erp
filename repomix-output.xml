              {error}
            </div>
          )}
          {loading && !item ? (
            <div className="text-sm text-gray-500">Loading item...</div>
          ) : (
            <ItemDetailContent
              itemId={id}
              item={item}
              onItemChange={setItem}
              saveSignal={saveVersion}
              onSavingChange={setSaving}
            />
          )}
        </div>
      </div>
    </div>
  );
}
