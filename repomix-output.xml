                              <span className="text-sm font-semibold text-gray-900">
                                {sectionLabels[section]}
                              </span>
                            </td>
                          </tr>
                          {lines.map((line) => (
                            <tr key={line.account_id} className="hover:bg-gray-50">
                              <td className="py-2 pl-4">
                                <div className="flex items-center gap-2">
                                  {line.account_number && (
